
@article{wong_iq-tree_2025,
	title = {{IQ}-{TREE} 3: {Phylogenomic} {Inference} {Software} using {Complex} {Evolutionary} {Models}},
	copyright = {CC BY Attribution 4.0 International},
	shorttitle = {{IQ}-{TREE} 3},
	url = {https://ecoevorxiv.org/repository/view/8916/},
	abstract = {IQ-TREE (http://www.iqtree.org) is a widely used open-source software tool for efficiently inferring phylogenetic trees under maximum likelihood. Here, we present IQ-TREE version 3, the third major release of the software. IQ-TREE 3 significantly extends version 2 with new features, including mixture models as an alternative to partitioned models, gene and site concordance factors to quantify discordance between genomic regions, and a fully-featured sequence simulator. The IQ-TREE 3 source code is available at https://github.com/iqtree/iqtree3.},
	language = {en},
	urldate = {2025-10-27},
	publisher = {EcoEvoRxiv},
	author = {Wong, Thomas K. F. and Ly-Trong, Nhan and Ren, Huaiyan and Baños, Hector and Roger, Andrew J. and Susko, Edward and Bielow, Chris and Maio, Nicola De and Goldman, Nick and Hahn, Matthew W. and Huttley, Gavin and Lanfear, Rob and Minh, Bui Quang},
	month = apr,
	year = {2025},
	file = {Full Text PDF:/Users/adry/Zotero/storage/XZGNGJ2Z/Wong et al. - 2025 - IQ-TREE 3 Phylogenomic Inference Software using Complex Evolutionary Models.pdf:application/pdf;Full Text PDF:/Users/adry/Zotero/storage/99DM7WWB/Wong et al. - 2026 - IQ-TREE 3 phylogenomic inference software using complex evolutionary models.pdf:application/pdf;Snapshot:/Users/adry/Zotero/storage/IXKKHDNV/msag117.html:text/html},
}

